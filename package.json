{
  "name": "dh-reporting-mobile",
  "version": "1.0.0",
  "type": "module",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build:android": "expo build:android",
    "build:ios": "expo build:ios",
    "sass:watch": "sass --watch src/styles:src/styles --style=compressed",
    "migration:create": "node src/scripts/migration.cjs create",
    "migration:install": "node src/scripts/migration.cjs install",
    "migration:downgrade": "node src/scripts/migration.cjs downgrade",
    "migration:status": "node src/scripts/migration.cjs status",
    "lint": "expo lint",
    "lint:fix": "expo lint -- --fix",
    "verify": "npm run lint && npm run typecheck && npm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@orenuki/dh-reporting-shared": "^1.0.11",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.5",
    "@react-navigation/drawer": "^7.5.6",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/stack": "^7.4.5",
    "@tanstack/react-query": "^5.83.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.0",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.10.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-date-picker": "^5.0.13",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-netinfo": "^1.1.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-sass-transformer": "^3.0.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "^0.5.1",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@tsconfig/react-native": "^3.0.9",
    "@types/jest": "29.5.14",
    "@types/react": "^19.1.10",
    "@types/react-native": "^0.72.8",
    "chalk": "^5.5.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "^54.0.17",
    "lint-staged": "^15.4.3",
    "sass": "^1.90.0",
    "typescript": "^5.9.3",
    "yargs": "^17.7.2"
  },
  "private": true,
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
